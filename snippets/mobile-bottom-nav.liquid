{% comment %} Mobile bottom navigation bar shown on mobile screens only {% endcomment %}
{% assign current_path = request.path %}
<nav class="mobile-bottom-nav" aria-label="Mobile navigation">
  <a href="{{ routes.root_url }}" class="mobile-bottom-nav__item{% if current_path == '/' %} mobile-bottom-nav__item--active{% endif %}"{% if current_path == '/' %} aria-current="page"{% endif %}>
    <span class="mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9.5L10 3l7 6.5V18a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5Z" />
        <path d="M7 18V11h6v7" />
      </svg>
    </span>
    <span class="mobile-bottom-nav__label">Home</span>
  </a>

  <button type="button" on:click="#search-modal/showDialog" class="mobile-bottom-nav__item{% if current_path contains '/search' %} mobile-bottom-nav__item--active{% endif %}"{% if current_path contains '/search' %} aria-current="page"{% endif %}>
    <span class="mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="9" r="4.5" />
        <path d="M14.5 14.5L18 18" />
      </svg>
    </span>
    <span class="mobile-bottom-nav__label">Search</span>
  </button>

  <a href="{{ routes.root_url }}collections/all" class="mobile-bottom-nav__item{% if current_path contains '/collections' %} mobile-bottom-nav__item--active{% endif %}"{% if current_path contains '/collections' %} aria-current="page"{% endif %}>
    <span class="mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3.5" y="4" width="13" height="12" rx="2" />
        <path d="M3.5 8.5h13" />
      </svg>
    </span>
    <span class="mobile-bottom-nav__label">Collections</span>
  </a>

  <button type="button" on:click="#cart-drawer/open" class="mobile-bottom-nav__item{% if current_path contains '/cart' %} mobile-bottom-nav__item--active{% endif %}"{% if current_path contains '/cart' %} aria-current="page"{% endif %}>
    <span class="mobile-bottom-nav__icon" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3h2l1 11h10l2-7H6" />
        <circle cx="8" cy="18" r="1" />
        <circle cx="15" cy="18" r="1" />
      </svg>
    </span>
    <span class="mobile-bottom-nav__label">Cart</span>
    {% if cart.item_count > 0 %}
      <span class="mobile-bottom-nav__badge">{{ cart.item_count }}</span>
    {% endif %}
  </button>
</nav>
